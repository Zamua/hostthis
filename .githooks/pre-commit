#!/usr/bin/env bash
# pre-commit hook for shale.
#
# What it checks (Go-only; no-op when no .go files are staged):
#   1. gofmt    every staged .go file is properly formatted
#   2. go vet   the whole module passes vet
#   3. golangci-lint (if installed) runs against the staged diff
#
# Activate once per clone:
#   git config core.hooksPath .githooks
#
# Install golangci-lint (pinned in .githooks/README.md):
#   brew install golangci-lint
#   # or: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2
#
# Bypass for one commit (use sparingly):
#   git commit --no-verify
set -euo pipefail

# Collect staged Go files (Added / Copied / Modified / Renamed).
staged_go=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.go$' || true)
if [ -z "$staged_go" ]; then
  exit 0
fi

# 1. gofmt: list any staged file whose formatting is off.
unformatted=$(printf '%s\n' "$staged_go" | xargs gofmt -l 2>/dev/null || true)
if [ -n "$unformatted" ]; then
  printf 'pre-commit: the following files are not gofmt-clean:\n%s\n' "$unformatted" >&2
  printf '\nRun:\n  gofmt -w %s\n' "$unformatted" >&2
  exit 1
fi

# 2. go vet across the whole module: fast and catches obvious issues.
#    GOWORK=off deliberately: gate the configuration that SHIPS, not the one
#    the developer happens to have. A go.work can replace a dependency with a
#    local checkout that is mid-refactor, on a different commit, or carrying
#    module-graph edges the released version resolves differently - so a
#    workspace vet can fail (or pass) where CI and the release build do the
#    opposite. A hook that gates a configuration nobody ships is worse than no
#    hook: it blocks good commits, which trains people to reach for
#    --no-verify, and it can miss real breakage in the build that matters.
if ! GOWORK=off go vet ./...; then
  printf 'pre-commit: go vet failed (GOWORK=off, matching CI)\n' >&2
  exit 1
fi

# 3. go fix modernize check: in Go 1.26 'go fix' is the modernizer suite.
#    '-diff' prints pending modernizations without applying; non-empty output
#    means un-modernized idioms are staged. (Default tags only; the cdylib
#    isn't assumed present, so slatedb-tagged files are checked by running
#    'go fix ./...' manually + the future slatedb CI job.)
#    GOWORK=off for the same reason as vet above. Note this step FAILS OPEN by
#    construction: '2>/dev/null || true' turns any error into empty output,
#    which reads as "nothing pending" and passes. So if the module graph will
#    not load, this check silently does not run rather than complaining - it
#    would look exactly like a clean result. Keeping it on the shipped
#    configuration is what stops that from happening quietly.
fix_pending=$(GOWORK=off go fix -diff ./... 2>/dev/null || true)
if [ -n "$fix_pending" ]; then
  printf 'pre-commit: pending Go modernizations. Run:\n  go fix ./...\nthen re-stage and re-commit.\n' >&2
  exit 1
fi

# 4. golangci-lint: only if installed. Skips with a warning otherwise so
#    a contributor without the tool installed isn't blocked from committing.
if command -v golangci-lint >/dev/null 2>&1; then
  if ! GOWORK=off golangci-lint run --new-from-rev HEAD --fix=false; then
    printf 'pre-commit: golangci-lint reported issues\n' >&2
    exit 1
  fi
else
  printf 'pre-commit: golangci-lint not installed; skipping lint pass.\n' >&2
  printf '            See .githooks/README.md for install instructions.\n' >&2
fi

exit 0
