# Operator-managed secrets + per-deployment knobs for hostthis VPS deploy.
# Copy to deploy/vps/.env, fill in real values, do NOT commit.
#
# docker compose reads .env automatically when invoked from this directory.
# `make deploy-sync` preserves .env on the VPS across rsyncs.

# Required: the public apex this deploy serves.
HOSTTHIS_APEX_DOMAIN=hostthis.dev

# Required: MinIO admin credentials. Used by docker compose to bring up
# MinIO on first boot. Treat as a password — generate randomly.
# `openssl rand -hex 32` is a fine source.
MINIO_ROOT_USER=hostthisadmin
MINIO_ROOT_PASSWORD=CHANGEME-32-byte-random-string

# Required if HOSTTHIS_BLOB_BACKEND=s3 — same values as MinIO admin
# work for the first cutover; create a scoped key for steady-state
# once things are stable.
HOSTTHIS_S3_ACCESS_KEY=hostthisadmin
HOSTTHIS_S3_SECRET_KEY=CHANGEME-32-byte-random-string

# Blob backend selector. Start at "disk" for first deploy, flip to
# "s3" after migration. Default in compose is "disk".
# HOSTTHIS_BLOB_BACKEND=s3

# CDN cache purger. Start at "noop"; flip to "cloudflare" + add token
# + zone-id once the CDN is set up.
# HOSTTHIS_CACHE_BACKEND=cloudflare
# HOSTTHIS_CF_PURGE_TOKEN=...
# HOSTTHIS_CF_ZONE_ID=...
